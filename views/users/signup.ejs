<% layout("layouts/boilerplate") %>
<div class="row mt-3">
      <h2 class="col-6 offset-3">SignUp on Wanderlust</h2>
    <div class="col-6 offset-3">
        <form action="/signup" method = "POST">
             <div class = "mb-3">
                    <label for="username" class = "form-label" class = "needs-validation" novalidation>
                        Username
                    </label>
                    <input type="text"
                    name="username" 
                    id = "username"
                    class = "form-control" required/>
                    <div class = 'valid-feedback'>Looks Good</div>
                </div>

                 <div class = "mb-3">
                    <label for="email" class = "form-label" class = "needs-validation" novalidation>
                        Email
                    </label>
                    <input type="email"
                    name="email" 
                    id = "email"
                    class = "form-control" required/>
                </div>

                 <div class = "mb-3">
                    <label for="password" class = "form-label" class = "needs-validation" novalidation>
                       Password
                    </label>
                    <input type="password"
                    name="password" 
                    id = "password"
                    class = "form-control" required/>
                </div>
                <button class = "btn btn-success">SignUp</button>
        </form>

    </div>
</div>